// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("admins")
}

model User {
  id          Int      @id @default(autoincrement())
  telegramId  String   @unique
  phoneNumber String
  username    String?
  fio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  image       String?
  price       Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[] // Связь с продуктами

  @@map("categories")
}

model Product {
  id           Int         @id
  name         String
  price        Float
  description  String?
  specs        String?
  image        String? // Путь к изображению
  fpsImage     String?
  allImages    String?
  favoriteRank Int?        @default(0) // Поле для ранжирования "лучших предложений"
  categoryId   Int
  category     Category    @relation(fields: [categoryId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]

  @@map("products")
}

model Order {
  id              Int          @id @default(autoincrement())
  userId          String // Telegram User ID
  userName        String // Имя пользователя из Telegram
  user            User?        @relation(fields: [userModelId], references: [id])
  userModelId     Int?
  total           Float
  status          String       @default("new") // new, processing, completed, cancelled
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  deliveryAddress String?
  comments        String?
  promocode       String?
  deliveryType    DeliveryType @default(PICKUP)
  payingType      PayingType   @default(CARD)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  items           OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

enum DeliveryType {
  MOSCOW
  CDEK
  PICKUP
}

enum PayingType {
  CARD
  CREDIT
  CASH
  OTHER
}
