# =================================
# TG SHOP - DOCKER CONFIGURATION
# =================================

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Администраторы (Telegram User ID через запятую)
ADMIN_IDS=123456789,987654321

# =================================
# DATABASE (PostgreSQL в Docker)
# =================================
POSTGRES_DB=tg-shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_123

# URL базы данных (для подключения из бэкенда к контейнеру postgres)
DATABASE_URL=postgresql://postgres:secure_password_123@postgres:5432/tg-shop

# =================================
# WEB APPLICATION
# =================================
# URL веб-приложения для Docker (nginx на порту 3000)
WEBAPP_URL=http://localhost:3000

# Порт бэкенда
PORT=3001

# =================================
# DOCKER SPECIFIC SETTINGS
# =================================
# Отключаем ngrok в Docker
USE_NGROK=false
NODE_ENV=production

# =================================
# VK CLOUD S3 STORAGE (опционально)
# =================================
VK_S3_ACCESS_KEY_ID=your_access_key
VK_S3_SECRET_ACCESS_KEY=your_secret_key
VK_S3_BUCKET_NAME=your_bucket_name
VK_S3_ENDPOINT=https://hb.ru-msk.vkcloud-storage.ru
VK_S3_REGION=ru-msk

# =================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# =================================
# Разработческие URL (не используются в Docker)
WEBAPP_DEV_URL=http://localhost:3001
NGROK_TOKEN=your_ngrok_token_for_dev 