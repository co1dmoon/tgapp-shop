# ===== Server =====
SERVER_DOMAIN=bzonetgstore.ru

# ===== Telegram Bot =====
BOT_TOKEN=REPLACE_ME
ADMIN_IDS=123456789

# ===== PostgreSQL =====
POSTGRES_DB=tgappshop
POSTGRES_USER=tgappshop
POSTGRES_PASSWORD=REPLACE_ME
DATABASE_URL=postgresql://tgappshop:REPLACE_ME@db:5432/tgappshop?schema=public

# ===== S3 (VK Cloud) =====
VK_S3_ACCESS_KEY_ID=REPLACE_ME
VK_S3_SECRET_ACCESS_KEY=REPLACE_ME
VK_S3_BUCKET_NAME=REPLACE_ME
# Опционально
VK_S3_ENDPOINT=https://s3.your-region.vkcloud.ru
VK_S3_REGION=your-region

# ===== Runtime =====
NODE_ENV=production
PORT=3001

