# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_BASE_URL=https://your-domain.com

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# Web App URL
WEBAPP_URL=https://your-domain.com/catalog.html

# AmoCRM Integration
AMO_CLIENT_ID=your_amo_client_id_here
AMO_CLIENT_SECRET=your_amo_client_secret_here
AMO_REDIRECT_URI=https://your-domain.com/amo-callback
AMO_DOMAIN=your-domain.amocrm.ru
# После первичной авторизации следует добавить эти токены:
AMO_ACCESS_TOKEN=
AMO_REFRESH_TOKEN=
# IDs для AmoCRM (посмотреть в настройках AmoCRM)
AMO_PIPELINE_ID=123456
AMO_NEW_STATUS_ID=123456
AMO_PHONE_FIELD_ID=123456
AMO_EMAIL_FIELD_ID=123456 