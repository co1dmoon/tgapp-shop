// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Модель для категорий товаров
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[] // Связь с продуктами

  @@map("categories")
}

// Модель для продуктов/товаров
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  description String?
  specs       String?
  image       String? // Путь к изображению
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inStock     Boolean  @default(true)

  // Связь с категорией
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  // Связь с заказами через промежуточную таблицу
  orderItems OrderItem[]

  @@map("products")
}

// Модель для заказов
model Order {
  id        Int      @id @default(autoincrement())
  userId    String // ID пользователя Telegram
  userName  String? // Имя пользователя Telegram
  status    String   @default("new") // new, paid, confirmed, completed, cancelled
  total     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связь с товарами через промежуточную таблицу
  items OrderItem[]

  // Контактная информация
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  deliveryAddress String?
  comments        String?

  @@map("orders")
}

// Промежуточная таблица для связи заказа и товаров (many-to-many)
model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int   @default(1)
  price    Float // Цена на момент заказа

  // Связи
  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// Модель для администраторов
model Admin {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("admins")
}
